# Nexus BNL v2.0 - Credenciales con Sistema de Fallback Multi-API
# NO SUBIR ESTE ARCHIVO A GITHUB
# Copia este archivo como .env y completa los valores

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# ===== NOTION =====
NOTION_TOKEN=tu_token_de_notion_aqui

# ===== GROQ (3 keys - cascada) =====
GROQ_API_KEY_1=tu_groq_key_1
GROQ_API_KEY_2=tu_groq_key_2
GROQ_API_KEY_3=tu_groq_key_3

# ===== GOOGLE GEMINI (2 keys - fallback) =====
GEMINI_API_KEY_1=tu_gemini_key_1
GEMINI_API_KEY_2=tu_gemini_key_2

# ===== DEEPSEEK (2 keys - fallback) =====
DEEPSEEK_API_KEY_1=tu_deepseek_key_1
DEEPSEEK_API_KEY_2=tu_deepseek_key_2

# ===== OPENROUTER (último recurso) =====
OPENROUTER_API_KEY=tu_openrouter_key

# ===== BACKEND API (legacy - para n8n) =====
API_KEY=cambia_esto_por_una_clave_segura
